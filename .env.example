# Rakshak AI - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# App name and version
VITE_APP_NAME=Rakshak AI
VITE_APP_VERSION=1.0.0

# Environment (development, staging, production)
VITE_APP_ENV=development

# ============================================
# GPS & LOCATION CONFIGURATION
# ============================================
# GPS update interval in milliseconds
VITE_GPS_UPDATE_INTERVAL=60000

# GPS accuracy preference (high, medium, low)
VITE_GPS_ACCURACY=medium

# Movement threshold in meters
VITE_MOVEMENT_THRESHOLD=10

# Stop duration threshold in milliseconds
VITE_STOP_DURATION_THRESHOLD=300000

# ============================================
# SAFETY MONITORING CONFIGURATION
# ============================================
# Safety check countdown in seconds
VITE_SAFETY_CHECK_COUNTDOWN=30

# Isolation radius in meters
VITE_ISOLATION_RADIUS=500

# Night time start hour (24-hour format)
VITE_NIGHT_TIME_START=18

# Night time end hour (24-hour format)
VITE_NIGHT_TIME_END=6

# ============================================
# TRIP SHARING CONFIGURATION
# ============================================
# Trip expiration in hours
VITE_TRIP_EXPIRATION_HOURS=24

# Location update interval in milliseconds
VITE_LOCATION_UPDATE_INTERVAL=30000

# ============================================
# OFFLINE CACHE CONFIGURATION
# ============================================
# Cache size limit in bytes (50MB default)
VITE_CACHE_SIZE_LIMIT=52428800

# Tile cache duration in days
VITE_TILE_CACHE_DAYS=7

# POI cache duration in hours
VITE_POI_CACHE_HOURS=24

# ============================================
# AI SAFETY CONFIGURATION
# ============================================
# AI analysis update interval in milliseconds
VITE_AI_UPDATE_INTERVAL=60000

# Risk score threshold for critical alerts
VITE_CRITICAL_RISK_THRESHOLD=80

# Risk score threshold for high alerts
VITE_HIGH_RISK_THRESHOLD=60

# Risk score threshold for medium alerts
VITE_MEDIUM_RISK_THRESHOLD=40

# ============================================
# NEARBY SEARCH CONFIGURATION
# ============================================
# Search radius in meters
VITE_SEARCH_RADIUS=2000

# Maximum results per category
VITE_MAX_RESULTS_PER_CATEGORY=20

# ============================================
# API CONFIGURATION
# ============================================
# API timeout in milliseconds
VITE_API_TIMEOUT=25000

# API retry attempts
VITE_API_RETRY_ATTEMPTS=3

# API retry delay in milliseconds
VITE_API_RETRY_DELAY=1000

# ============================================
# ANALYTICS CONFIGURATION (Optional)
# ============================================
# Google Analytics ID (optional)
VITE_GA_ID=

# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
# Enable AI safety features
VITE_ENABLE_AI_SAFETY=true

# Enable offline mode
VITE_ENABLE_OFFLINE_MODE=true

# Enable trip sharing
VITE_ENABLE_TRIP_SHARING=true

# Enable path recovery
VITE_ENABLE_PATH_RECOVERY=true

# Enable night mode
VITE_ENABLE_NIGHT_MODE=true

# Enable safety monitoring
VITE_ENABLE_SAFETY_MONITORING=true

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Enable rate limiting
VITE_ENABLE_RATE_LIMITING=true

# Rate limit requests per minute
VITE_RATE_LIMIT_PER_MINUTE=60

# Enable CSRF protection
VITE_ENABLE_CSRF_PROTECTION=true

# ============================================
# DEVELOPMENT CONFIGURATION
# ============================================
# Enable debug mode
VITE_DEBUG=true

# Enable console logging
VITE_ENABLE_CONSOLE_LOGGING=true

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false
